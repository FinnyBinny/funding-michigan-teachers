# ─────────────────────────────────────────────────────────────────────────────
# Funding Michigan Teachers — Environment Variables
# Copy this file to .env.local and fill in your values.
# Add the same keys to Vercel: vercel.com → Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (vote persistence) ───────────────────────────────────────────────
# 1. Create a free project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy "Project URL" and "anon public" key below
# 4. Run the SQL in SUPABASE_SETUP.sql in the Supabase SQL Editor
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Web3Forms (contact / newsletter / project submission emails) ──────────────
# 1. Sign up free at https://web3forms.com
# 2. Enter the email where you want to receive submissions (e.g. edu@fundingmichiganteachers.org)
# 3. Check that inbox for your access key
VITE_WEB3FORMS_KEY=your-web3forms-access-key-here
